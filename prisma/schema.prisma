generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("User")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poolsOwned       Pool[]             @relation("PoolOwner")
  poolParticipants PoolParticipant[]
  predictions      Prediction[]
  predictionScores PredictionScore[]
  doublePickPicks  DoublePointPick[]
  userBadges       UserBadge[]
}

model Team {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  group          String?
  flagUrl        String?
  primaryColor   String?
  secondaryColor String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homePlayers Player[]      @relation("TeamPlayers")
  homeMatches Match[]       @relation("HomeTeam")
  awayMatches Match[]       @relation("AwayTeam")
}

model Player {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  number    Int?
  position  String?
  club      String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation("TeamPlayers", fields: [teamId], references: [id], onDelete: Cascade)
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches Match[]
}

model Stadium {
  id        String   @id @default(cuid())
  name      String
  city      String
  country   String
  capacity  Int?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches Match[]
}

model Round {
  id          String   @id @default(cuid())
  name        String
  description String?
  phase       String   @default("GroupStage")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches         Match[]
  doublePickPicks DoublePointPick[]
}

model Match {
  id         String   @id @default(cuid())
  homeTeamId String
  awayTeamId String
  groupId    String?
  stadiumId  String?
  roundId    String?
  matchDate  DateTime
  homeScore  Int?
  awayScore  Int?
  status     String   @default("Scheduled")
  phase      String   @default("GroupStage")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeTeam        Team              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        Team              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  group           Group?            @relation(fields: [groupId], references: [id])
  stadium         Stadium?          @relation(fields: [stadiumId], references: [id])
  round           Round?            @relation(fields: [roundId], references: [id])
  predictions     Prediction[]
  predictionScores PredictionScore[]
  doublePickPicks DoublePointPick[]
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  category    String?
  condition   String?
  points      Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBadges UserBadge[]
}

model Pool {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  ownerId     String
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner           User              @relation("PoolOwner", fields: [ownerId], references: [id])
  participants    PoolParticipant[]
  scoringSettings PoolScoringSettings?
  predictions     Prediction[]
  predictionScores PredictionScore[]
  doublePickPicks DoublePointPick[]
  userBadges      UserBadge[]
}

model PoolParticipant {
  id             String   @id @default(cuid())
  poolId         String
  userId         String
  role           String   @default("Member")
  joinedAt       DateTime @default(now())
  totalPoints    Int      @default(0)
  exactScores    Int      @default(0)
  correctResults Int      @default(0)
  currentStreak  Int      @default(0)
  bestStreak     Int      @default(0)
  badgesCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId])
}

model PoolScoringSettings {
  id                   String   @id @default(cuid())
  poolId               String   @unique
  correctResultPoints  Int      @default(3)
  goalDifferencePoints Int      @default(2)
  totalGoalsPoints     Int      @default(2)
  exactScorePoints     Int      @default(10)
  doubleMultiplier     Int      @default(2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
}

model Prediction {
  id                  String   @id @default(cuid())
  poolId              String
  userId              String
  matchId             String
  predictedHomeScore  Int
  predictedAwayScore  Int
  isLocked            Boolean  @default(false)
  submittedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt

  pool  Pool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  score PredictionScore?

  @@unique([poolId, userId, matchId])
}

model PredictionScore {
  id                   String   @id @default(cuid())
  predictionId         String   @unique
  poolId               String
  userId               String
  matchId              String
  resultPoints         Int      @default(0)
  goalDifferencePoints Int      @default(0)
  totalGoalsPoints     Int      @default(0)
  exactScorePoints     Int      @default(0)
  doubleMultiplier     Int      @default(1)
  totalPoints          Int      @default(0)
  explanation          String?
  calculatedAt         DateTime @default(now())

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  pool       Pool       @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model DoublePointPick {
  id        String   @id @default(cuid())
  poolId    String
  userId    String
  roundId   String
  matchId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pool  Pool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId, roundId])
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  poolId   String
  badgeId  String
  earnedAt DateTime @default(now())
  metadata String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool  Pool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId, badgeId])
}

model ImportBatch {
  id             String      @id @default(cuid())
  type           String
  status         String      @default("Pending")
  totalFiles     Int         @default(0)
  processedFiles Int         @default(0)
  createdAt      DateTime    @default(now())
  finishedAt     DateTime?

  files          ImportFile[]
}

model ImportFile {
  id             String      @id @default(cuid())
  importBatchId  String
  fileName       String
  entityType     String
  status         String      @default("Pending")
  totalRecords   Int         @default(0)
  createdRecords Int         @default(0)
  updatedRecords Int         @default(0)
  errorMessage   String?
  createdAt      DateTime    @default(now())
  finishedAt     DateTime?

  batch          ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
}
